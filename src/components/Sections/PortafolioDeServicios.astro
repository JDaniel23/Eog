---
import Titulo from "../body/Titulo.astro"
import Subtitulo from "../body/Subtitulo.astro"
import portafolio from "../../assets/Portafolio.jpeg"
const {id}=Astro.props
---
<div class="px-6 lg:px-16 min-h-dvh bg-black py-20">
    <section id={id} class="bg-[url(/src/assets/fondogris.jpeg)] rounded-xl overflow-hidden" >
    <div class="p-6">
        <Titulo title="PORTAFOLIO DE SERVICIOS"/>
        
    </div>
    <div class="grid mt-4 lg:grid-cols-2 ">
        <div class="p-10 mt-6 ml-6">
            <Subtitulo title="CONSULTORÍA ESTRATÉGICA Y GESTIÓN DE
ACTIVOS"/>
                <ul class="ml-2">
                   <li class="text-xl lg:text-2xl text-white">Estudios de Viabilidad y Pre-Inversión (FEL 1, FEL 2)</li>
                   <li class="text-xl lg:text-2xl text-white">Gestión de Integridad de Activos</li>
                   <li class="text-xl lg:text-2xl text-white">Rehabilitación de infraestructura existente</li>
                   <li class="text-xl lg:text-2xl text-white">Apoyo operacional</li>
                   <li class="text-xl lg:text-2xl text-white">Mantenimiento, RCM y extensión de vida útil</li>
                   <li class="text-xl lg:text-2xl text-white">Eficiencia Energética y reducción de huella de carbono</li>
                   <li class="text-xl lg:text-2xl text-white">Compliance de normativa local/internacional</li>
                </ul>
                <Subtitulo title="Proyectos IPC (EPC Management)"/>
             
                <p class="font-subtitulos text-xl lg:text-2xl mt-4 text-white">Ingeniería Desarrollo de ingeniería conceptual, básica y de
detalle. Revisión de ingeniería de terceros (Peer Review).</p>
        </div>
        <div>
             <div class="border-l-2 border-white p-10 mt-6 ">
            <ul class="ml-10">
                <li>
                    <Subtitulo title="Procura Técnica"/>
               
                <p class="font-subtitulos text-xl lg:text-2xl text-white text-justify">
                   Gestión estratégica de compras, inspección en fábrica
(FAT), logística internacional y nacionalización de equipos
críticos (válvulas, tuberías, instrumentación, rotativos).
                </p>
            </li>

               <li>
                <Subtitulo title="Gerencia y Supervisión de Construcción"/>
                <p class="font-subtitulos text-xl lg:text-2xl text-white text-justify">
                   Supervisión en campo, control de obra, aseguramiento de
calidad (QA/QC) y gestión de contratistas
                </p>
            </li>

             <li>
                <Subtitulo title="Comisionamiento y Puesta en Marcha"/>
               
                <p class="font-subtitulos text-xl lg:text-2xl text-white text-justify">
                 Protocolos de arranque seguro y entrega de
instalaciones.
                </p>
            </li>

             <li>
               
                <Subtitulo title="Capacitación y Entrenamiento (EO&G Academy)
Escuela Técnica"/> 

                <p class=" font-subtitulos text-xl lg:text-2xl text-white text-justify">
                Cursos especializados en normas API, soldadura,
inspección de equipos estáticos y rotativos,
instrumentación y control.
                </p>
            </li>
            </ul>
        </div>
        </div>

    </div>


</section>



<section class=" grid md:grid-cols-2 gap-1.5 py-20">

<div class=" bg-[url(/src/assets/fondogris.jpeg)] p-10 ">
    <Titulo title="PORTAFOLIO DE SERVICIOS"/>
    <ul>
        <li class="mt-4">
            <Subtitulo title="Escuela de Gerencia de Proyectos"/>
           
            <p class=" font-subtitulos text-xl mt-2 lg:text-2xl text-white text-justify">
                 Formación en metodologías ágiles y predictivas para el
sector construcción y energía.
        </li>

        <li  class="mt-4">
            <Subtitulo title="Seguridad Industrial (HSE)" />
            <p class="font-subtitulos text-xl mt-2 lg:text-2xl text-white text-justify">
               Certificaciones en manejo de riesgos, permisos de
trabajo y respuesta a emergencias.
        </li>

         <li  class="mt-4">
            <Subtitulo title="Programas In-Company"/>
            <p class="font-subtitulos text-xl mt-2 lg:text-2xl text-white text-justify">
               Mallas curriculares diseñadas a la medida de las
necesidades operativas del cliente.
        </li>     
    </ul>
</div>
<div>
<div class="rounded-xl overflow-hidden">
    <img src={portafolio.src} alt="Portafolio de servicios">
</div>
</div>


</section>
</div>



