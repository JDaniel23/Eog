<section id={id} class="min-h-dvh py-16 px-6 lg:px-16 grid lg:grid-cols-2 gap-12 bg-black items-center">
    
    <div class="flex flex-col justify-center space-y-8">
        
        <Titulo title="RAZON DE SER"/>
        
        <div class="flex flex-col gap-10 border-l-4 px-6 border-white"> <div class="space-y-3">
                <Subtitulo title="MISIÓN"/>
                <p class="font-subtitulos text-white text-lg lg:text-xl text-justify leading-relaxed">
                    Maximizar la rentabilidad y sostenibilidad de infraestructuras
                    energéticas e industriales, mediante una gestión eficiente de
                    activos, con criterios de innovación y sostenibilidad; a través de
                    la ejecución de proyectos IPC, consultorías especializadas y
                    formación de talento.
                </p>
            </div>

            <div class="space-y-3">
                <Subtitulo title="VISIÓN"/>
                <p class="font-subtitulos text-white text-lg lg:text-xl text-justify leading-relaxed">
                    Ser la firma de referencia regional en revitalización de
                    activos y desarrollo de proyectos energéticos.
                </p>
            </div>      
        </div>
    </div>
    
    <div class="rounded-2xl overflow-hidden shadow-2xl h-full max-h-[600px]">
        <img class="object-cover w-full h-full" src={Razondeser.src} alt="Razón de ser">
    </div>

</section>