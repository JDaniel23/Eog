 <section id={id} class="min-h-dvh bg-black py-20 px-6 lg:px-16 ">
    <div class="mb-12">
        <Titulo title="PROPUESTA DE VALOR DIFERENCIAL"/>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 items-start">
        
        <div class="flex flex-col  gap-10">
            <ul class="space-y-10">
                <li class="border-l-2 border-white pl-6">
                    <Subtitulo title="Experiencia"/>
                    <p class="font-subtitulos text-xl lg:text-2xl text-white mt-2">
                        Integramos un grupo de expertos, con más de 40 años de experiencia en instalaciones industriales y de petróleo y gas.
                    </p>
                </li>

                <li class="border-l-2 border-white pl-6">
                    <Subtitulo title="Especialistas en rehabilitación"/>
                    <p class="font-subtitulos text-xl lg:text-2xl text-white mt-2">
                        Implementamos soluciones para prolongar la operatividad de instalaciones críticas, mediante el diagnóstico y rehabilitación de infraestructura existente.
                    </p>
                </li>

                <li class="border-l-2 border-white pl-6">
                    <Subtitulo title="Innovación"/>
                    <p class="font-subtitulos text-xl lg:text-2xl text-white mt-2">
                        Incorporamos soluciones tecnológicas de vanguardia y última generación.
                    </p>
                </li>

                <li class="border-l-2 border-white pl-6">
                    <Subtitulo title="Competitividad"/>
                    <p class="font-subtitulos text-xl lg:text-2xl text-white mt-2">
                        Costos de servicios competitivos en relación con empresas internacionales.
                    </p>
                </li>

                <li class="border-l-2 border-white pl-6">
                    <Subtitulo title="Conocimiento del nicho"/>
                    <p class="font-subtitulos text-xl lg:text-2xl text-white mt-2">
                        Aliado clave en la ejecución de proyectos complejos bajo criterios eficientes de CAPEX y OPEX. Conocimiento profundo del parque industrial.
                    </p>
                </li>
            </ul>
        </div>

        <div class="lg:sticky lg:top-24">
            <div class="rounded-2xl overflow-hidden shadow-2xl border border-white/10">
                <img class="object-cover w-full h-auto" src={PropuestaValor.src} alt="Propuesta de valor">
            </div>
        </div>
        
    </div>
</section>